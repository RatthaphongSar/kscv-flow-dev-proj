{
  "info": {
    "_postman_id": "kvc-api-collection",
    "name": "KVC API Testing",
    "description": "Collection for testing KVC Backend API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login - Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"student-demo\",\"password\":\"Student123!\"}"
            },
            "url": {
              "raw": "http://localhost:4001/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4001",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login - Teacher",
          "request": {
            "method": "POST",
