    {
      "name": "Chat",
      "item": [
        {
          "name": "List Rooms (by userId)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:4001/api/chat/rooms?userId=student-demo",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4001",
              "path": ["api", "chat", "rooms"],
              "query": [
                {
                  "key": "userId",
                  "value": "student-demo"
                }
              ]
            }
          }
        },
        {
          "name": "Create Room",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Test Room\",\"memberIds\":[]}"
            },
            "url": {
              "raw": "http://localhost:4001/api/chat/rooms",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4001",
              "path": ["api", "chat", "rooms"]
            }
          }
        },
        {
          "name": "Auto Generate Rooms",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:4001/api/chat/rooms/auto",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4001",
              "path": ["api", "chat", "rooms", "auto"]
            }
          }
        },
        {
          "name": "List Messages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:4001/api/chat/rooms/ROOM_ID/messages?limit=50",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4001",
              "path": ["api", "chat", "rooms", "ROOM_ID", "messages"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"userId\":\"student-demo\",\"content\":\"Hello world!\"}"
            },
            "url": {
              "raw": "http://localhost:4001/api/chat/rooms/ROOM_ID/messages",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4001",
              "path": ["api", "chat", "rooms", "ROOM_ID", "messages"]
            }
          }
        }
      ]
