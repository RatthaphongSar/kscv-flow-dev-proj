{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm run start",
    "restartPolicyMaxRetries": 5
  },
  "services": {
    "backend": {
      "build": {
        "context": "./backend",
        "dockerfile": "Dockerfile"
      },
      "port": 4001,
      "environment": {
        "NODE_ENV": "production",
        "PORT": "4001",
        "CORS_ORIGIN": "*"
      }
    },
    "frontend": {
      "build": {
        "context": "./frontend",
        "dockerfile": "Dockerfile"
      },
      "port": 3000,
      "environment": {
        "VITE_BACKEND_URL": "${{ services.backend.url }}/api"
      }
    }
  }
}
