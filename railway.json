{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "build": {
        "context": "./backend",
        "dockerfile": "Dockerfile"
      },
      "port": 4001,
      "environment": {
        "NODE_ENV": "production",
        "PORT": "4001",
        "CORS_ORIGIN": "*"
      }
    },
    "frontend": {
      "build": {
        "context": "./frontend",
        "dockerfile": "Dockerfile"
      },
      "port": 3000,
      "environment": {
        "PORT": "3000",
        "VITE_BACKEND_URL": "http://backend:4001"
      }
    },
    "postgres": {
      "image": "postgres:16-alpine",
      "port": 5432,
      "environment": {
        "POSTGRES_DB": "kvcdb",
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "kvc2025!"
      }
    },
    "redis": {
      "image": "redis:7-alpine",
      "port": 6379
    }
  }
}
