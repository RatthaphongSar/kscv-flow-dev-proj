# KSVC Connect Backend Environment Variables
# Copy this file to .env and update the values

# Server Configuration
PORT=4001
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://your-frontend-domain.com

# Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:kvc2025!@localhost:5432/kvcdb"

# Security (JWT)
# Use complex random strings for these secrets
JWT_ACCESS_SECRET=change_this_to_a_secure_random_string_access
JWT_REFRESH_SECRET=change_this_to_a_secure_random_string_refresh
COOKIE_SECRET=change_this_to_a_secure_random_string_cookie

# Token Expiry
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# HTTPS (Optional - Recommended for production if not using a reverse proxy)
HTTPS=0
HTTPS_PORT=4001
HTTPS_CERT_PATH=certs/fullchain.pem
HTTPS_KEY_PATH=certs/privkey.pem

# AI Provider (Optional)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
