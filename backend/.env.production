# KVC Backend - Production Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# Server Configuration
# ============================================
PORT=4001
NODE_ENV=production
HTTPS=1
HTTPS_PORT=4001

# ============================================
# Database Configuration
# ============================================
# Production PostgreSQL URL
DATABASE_URL=https://kscv-flow-dev-proj.onrender.com

# ============================================
# Authentication & Security
# ============================================
# JWT Secrets - MUST be changed in production

JWT_ACCESS_SECRET=a3f8e2d1c9b4a7f2e8d1c3b5a7f9e2d4c6b8a1f3e5d7c9b1a3f5e7d9c1b3a5
JWT_REFRESH_SECRET=b4f9e3d2c0b5a8f3e9d2c4b6a8f0e3d5c7b9a2f4e6d8c0b2a4f6e8d0c2b4a6
COOKIE_SECRET=https://kscv-flow-dev-proj-wi31.vercel.app/

# Token Expiration
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# ============================================
# CORS & Domain Configuration
# ============================================
# Production domain and allowed origins
CORS_ORIGIN=https://kvc.ac.th,https://www.kvc.ac.th,/^https:\/\/preview-.*\.kvc\.ac\.th$/
CORS_CREDENTIALS=true

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=60000    # 1 minute
RATE_LIMIT_MAX=120             # 120 requests per minute

# ============================================
# SSL/HTTPS Configuration
# ============================================
HTTPS_CERT_PATH=/etc/nginx/certs/server.crt
HTTPS_KEY_PATH=/etc/nginx/certs/server.key

# ============================================
# AI/OpenAI Configuration
# ============================================
AI_PROVIDER=openai
OPENAI_API_KEY=sk-CHANGE_ME_WITH_YOUR_API_KEY
OPENAI_MODEL=gpt-4o-mini

# ============================================
# Redis Configuration (Optional - for caching)
# ============================================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=CHANGE_ME_PASSWORD

# ============================================
# Email Configuration (Optional - for notifications)
# ============================================
# SMTP_HOST=mail.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@kvc.ac.th
# SMTP_PASSWORD=CHANGE_ME_PASSWORD
# SMTP_FROM=noreply@kvc.ac.th

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info
LOG_FILE=/var/log/kvc-backend/app.log

# ============================================
# Vector/RAG Configuration (Optional - for future)
# ============================================
# VECTOR_PROVIDER=pgvector|weaviate|pinecone
# VECTOR_DB_URL=postgresql://...

# ============================================
# Additional Security
# ============================================
HELMET_ENABLED=true
COMPRESSION_ENABLED=true
REQUEST_SIZE_LIMIT=20mb

# ============================================
# Monitoring & Analytics (Optional)
# ============================================
# SENTRY_DSN=https://...@sentry.io/...
# DATADOG_API_KEY=CHANGE_ME

# ============================================
# Feature Flags
# ============================================
FEATURE_CHAT_ENABLED=true
FEATURE_AI_ASSISTANT_ENABLED=true
FEATURE_EXPORT_ENABLED=true
FEATURE_VIDEO_CONFERENCING_ENABLED=true
