OPENAI_API_KEY=sk-CHANGE_ME_WITH_YOUR_API_KEY
# ============================================
# Feature Flags
# ============================================
FEATURE_CHAT_ENABLED=true
FEATURE_AI_ASSISTANT_ENABLED=true
FEATURE_EXPORT_ENABLED=true
FEATURE_VIDEO_CONFERENCING_ENABLED=true
