generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // ← ดึงจาก .env
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String? // optional สำหรับ system/assistant user
  email        String?  @unique
  phone        String?
  role         String   @default("STUDENT") // STUDENT, TEACHER, ADMIN
  year         Int      @default(1)
  major        String   @default("General")
  fullname     String?  // Full name or display name
  studentId    String?  // Student ID number
  address      String?  // Home address
  avatar       String?  // Avatar URL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Chat Relations
  roomMembers  RoomMember[]
  messages     Message[]
  chatNotes    ChatNote[]
  uploadedFiles ChatFile[]
  messageReads MessageRead[]
  pinnedRooms  RoomPin[]
  deletedMessages DeletedMessagePerUser[]
  pinnedMessages PinnedMessage[]

  // Academic Relations
  teacherClasses  Class[]  @relation("TeacherClasses")
  studentEnrollments Enrollment[] @relation("StudentEnrollments")
  studentJoinRequests JoinRequest[] @relation("StudentJoinRequests")
  teacherAssignments Assignment[] @relation("TeacherAssignments")
  assignmentSubmissions AssignmentSubmission[]

  studentAttendances Attendance[] @relation("StudentAttendance")
  studentAssemblyAttendances AssemblyAttendance[] @relation("StudentAssemblyAttendance")

  gradeRecords   GradeRecord[] @relation("StudentGrades")
  studentExamGrades Grade[] @relation("StudentExamGrades")
  studentLeaves  Leave[] @relation("StudentLeaves")
  advisorApprovals Leave[] @relation("AdvisorApprovals")

  advisor      Advisor?
  clubMembers  ClubMember[]
  organizations ClassOrganization[]
  communities  CommunityMember[]
  serviceRequests ServiceRequest[]

  // Video Conferencing Relations
  videoParticipants VideoParticipant[] @relation("UserVideoParticipant")
  screenSessions ScreenShareSession[] @relation("ScreenPresenter")
  chatMessages ChatMessage[] @relation("ChatSender")

  // Meeting Relations
  teacherMeetings Meeting[] @relation("TeacherMeetings")
  studentMeetings MeetingParticipant[] @relation("StudentMeetings")

  // Announcement Relations
  announcements   Announcement[] @relation("TeacherAnnouncements")

  @@index([role, year, major])
}

model Room {
  id       String       @id @default(cuid())
  name     String       @unique
  type     String
  members  RoomMember[]
  messages Message[]
  notes    ChatNote[]
  files    ChatFile[]
  pins     RoomPin[]
  pinnedMessages PinnedMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomMember {
  id String @id @default(cuid())

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  userId String
  room   Room   @relation(fields: [roomId], references: [id])
  roomId String

  @@unique([roomId, userId], name: "roomId_userId")
  @@index([userId])
  @@index([roomId])
}

model Message {
  id        String   @id @default(cuid())
  content   String?
  type      String   @default("text") // text, image, file
  createdAt DateTime @default(now())
  edited    Boolean  @default(false)
  editedAt  DateTime?
  deletedForEveryone Boolean @default(false)  // ลบสำหรับทุกคน

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  
  // Reply support
  replyTo      Message?  @relation("MessageReply", fields: [replyToId], references: [id], onDelete: Cascade)
  replyToId    String?
  repliedBy    Message[] @relation("MessageReply")

  // File/Image attachments
  files     ChatFile[] @relation("MessageFiles")
  file      ChatFile? @relation("MessageFile", fields: [fileId], references: [id])
  fileId    String?   @unique

  // Read receipts for this message
  readReceipts MessageRead[]

  // Delete tracking per user (ลบเฉพาะสำหรับตัวเอง)
  deletedForUsers DeletedMessagePerUser[]

  // Pinned messages
  pinnedIn PinnedMessage[]

  @@index([roomId, createdAt])
  @@index([replyToId])
  @@index([userId])
}

// ============ MESSAGE DELETION PER USER ============
model DeletedMessagePerUser {
  id        String   @id @default(cuid())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  deletedAt DateTime @default(now())

  @@unique([messageId, userId])
  @@index([userId])
  @@index([messageId])
}

// ============ PINNED MESSAGES ============
model PinnedMessage {
  id        String   @id @default(cuid())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  user      User     @relation(fields: [pinnedBy], references: [id], onDelete: Cascade)
  pinnedBy  String
  pinnedAt  DateTime @default(now())

  @@unique([messageId, roomId])
  @@index([roomId, pinnedAt])
  @@index([pinnedBy])
}

// ============ ACADEMIC MODELS ============

model Assignment {
  id                    String   @id @default(cuid())
  title                 String
  description           String?
  assignmentType        String   @default("homework") // homework, quiz, project, exam
  maxScore              Float    @default(100)
  assignedAt            DateTime @default(now())       // เวลาที่ครูสั่งงาน
  dueDate               DateTime                        // เดทไลน์ส่งงาน
  requiredFilesCount    Int      @default(1)           // จำนวนไฟล์ที่ต้องส่ง
  maxSubmissionCount    Int      @default(1)           // จำนวนครั้งที่อนุญาตให้ส่ง
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  teacher               User     @relation("TeacherAssignments", fields: [teacherId], references: [id])
  teacherId             String
  class                 Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId               String

  submissions           AssignmentSubmission[]

  @@index([classId, dueDate])
  @@index([classId, assignedAt])
  @@index([teacherId])
}

model AssignmentSubmission {
  id                String   @id @default(cuid())
  submittedAt       DateTime @default(now())
  fileUrl           String?
  content           String?
  grade             Float?
  feedback          String?
  status            String   @default("not_submitted") // not_submitted, submitted, graded, late, requested_resubmit
  submissionCount   Int      @default(0) // จำนวนครั้งที่ส่งแล้ว
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  student           User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId         String
  assignment        Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId      String

  @@unique([assignmentId, studentId])
  @@index([studentId, submittedAt])
  @@index([status])
}

model Attendance {
  id        String   @id @default(cuid())
  date      DateTime
  status    String   @default("absent") // present, absent, late, excuse
  remark    String?
  checkinAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  student   User   @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  class     Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId   String
  session   AttendanceSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  sessionId String?

  @@unique([studentId, classId, date])
  @@index([classId, date])
  @@index([studentId])
  @@index([sessionId])
}

model AssemblyAttendance {
  id        String   @id @default(cuid())
  date      DateTime
  status    String   @default("absent") // present, late, absent
  remark    String?
  checkinAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   User   @relation("StudentAssemblyAttendance", fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  class     Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId   String

  @@unique([studentId, classId, date])
  @@index([classId, date])
  @@index([studentId])
}

model AttendanceSession {
  id          String   @id @default(cuid())
  subject     String   // เรียน/สอบ/เก็บคะแนน
  type        String   // lesson, midterm, final, quiz, collection
  startDate   DateTime
  endDate     DateTime?
  status      String   @default("active") // active, completed, cancelled
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId     String
  attendances Attendance[]

  @@index([classId])
  @@index([startDate])
}

model Exam {
  id        String   @id @default(cuid())
  title     String
  subject   String
  date      DateTime
  room      String?
  duration  Int?     // in minutes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId String

  grades Grade[]

  @@index([classId, date])
}

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("online") // online | onsite
  platform    String?  // Microsoft Teams, Google Meet, Zoom, etc (only for online)
  location    String?  // Room number/name (only for onsite)
  startTime   DateTime
  endTime     DateTime
  status      String   @default("scheduled") // scheduled | active | completed | cancelled
  capacity    Int?     // Max participants
  
  // Video conferencing features
  recordingStartedAt   DateTime?
  recordingStoppedAt   DateTime?
  recordingUrl         String?        // S3/storage URL
  recordingDuration    Int?           // in seconds
  hasTranscription     Boolean        @default(false)
  transcriptionUrl     String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  teacher     User     @relation("TeacherMeetings", fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId   String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId     String
  participants MeetingParticipant[]
  videoSessions VideoSession[]
  screenSessions ScreenShareSession[]
  callStats CallStats[]
  chatMessages ChatMessage[]

  @@index([classId, startTime])
  @@index([teacherId, startTime])
  @@index([status])
}

model MeetingParticipant {
  id        String   @id @default(cuid())
  status    String   @default("joined") // joined | left | declined
  joinedAt  DateTime @default(now())
  leftAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String
  student   User    @relation("StudentMeetings", fields: [studentId], references: [id], onDelete: Cascade)
  studentId String

  @@unique([meetingId, studentId])
  @@index([meetingId])
  @@index([studentId])
}

// ============ VIDEO CONFERENCING MODELS ============

model VideoSession {
  id              String    @id @default(cuid())
  status          String    @default("active") // active | completed | failed
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  recordingUrl    String?   // S3 storage
  recordingSize   Int?      // bytes
  duration        Int?      // seconds
  
  // Relations
  meeting         Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId       String
  participants    VideoParticipant[]
  stats           CallStats[]
  
  @@index([meetingId, startedAt])
}

model VideoParticipant {
  id              String    @id @default(cuid())
  userId          String
  joinedAt        DateTime  @default(now())
  leftAt          DateTime?
  
  // Video quality metrics
  videoEnabled    Boolean   @default(true)
  audioEnabled    Boolean   @default(true)
  screenShared    Boolean   @default(false)
  
  // Stats
  videoQuality    String?   // HD, SD, LOW
  audioQuality    String?   // excellent, good, fair, poor
  jitterMs        Int?      // milliseconds
  packetLoss      Float?    // percentage
  
  // Relations
  user            User      @relation("UserVideoParticipant", fields: [userId], references: [id], onDelete: Cascade)
  session         VideoSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId       String
  
  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model ScreenShareSession {
  id              String    @id @default(cuid())
  presenterId     String
  screenUrl       String?   // Recording of screen
  startedAt       DateTime  @default(now())
  stoppedAt       DateTime?
  duration        Int?
  
  // Relations
  presenter       User      @relation("ScreenPresenter", fields: [presenterId], references: [id], onDelete: Cascade)
  meeting         Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId       String
  
  @@index([meetingId, startedAt])
  @@index([presenterId])
}

model CallStats {
  id              String    @id @default(cuid())
  
  // Video metrics
  videoBitrate    Int?      // kbps
  videoFramerate  Int?      // fps
  videoResolution String?   // 1920x1080, 1280x720, etc
  
  // Audio metrics
  audioBitrate    Int?      // kbps
  audioLevel      Int?      // 0-100
  
  // Network metrics
  latencyMs       Int?      // round trip time
  jitterMs        Int?      // variation
  packetLossPercent Float?
  bandwidth       Int?      // kbps available
  
  recordedAt      DateTime  @default(now())
  
  // Relations
  session         VideoSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId       String
  meeting         Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId       String
  
  @@index([sessionId, recordedAt])
  @@index([meetingId])
}

model ChatMessage {
  id              String    @id @default(cuid())
  content         String
  senderName      String
  createdAt       DateTime  @default(now())
  
  // Relations
  sender          User      @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)
  senderId        String
  meeting         Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId       String
  
  @@index([meetingId, createdAt])
  @@index([senderId])
}

model Grade {
  id        String   @id @default(cuid())
  score     Float
  maxScore  Float    @default(100)
  percentage Float?
  grade     String?  // A, B, C, D, F
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  student User   @relation("StudentExamGrades", fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  exam    Exam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  examId  String

  @@unique([examId, studentId])
  @@index([studentId, score])
}

model Leave {
  id        String   @id @default(cuid())
  type      String   // sick, personal, ordination, other
  startDate DateTime
  endDate   DateTime
  reason    String?
  status    String   @default("pending") // pending, approved, rejected
  docUrl    String?  // doctor certificate for sick leave
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  student   User   @relation("StudentLeaves", fields: [studentId], references: [id])
  studentId String
  advisor   User?  @relation("AdvisorApprovals", fields: [advisorId], references: [id])
  advisorId String?

  @@index([studentId, status])
}

model Club {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members ClubMember[]
  activities ClubActivity[]

  @@index([name])
}

model ClubMember {
  id String @id @default(cuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String
  club   Club   @relation(fields: [clubId], references: [id])
  clubId String
  role   String @default("member") // member, officer, president

  @@unique([clubId, userId])
  @@index([userId])
}

model ClubActivity {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  imageUrl    String?
  createdAt   DateTime @default(now())

  club   Club   @relation(fields: [clubId], references: [id])
  clubId String

  @@index([clubId, date])
}

model Schedule {
  id        String   @id @default(cuid())
  dayOfWeek Int      // 0=Monday, 4=Friday
  startTime String   // HH:mm format
  endTime   String   // HH:mm format
  room      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId String

  @@unique([classId, dayOfWeek, startTime])
}

model Class {
  id              String   @id @default(cuid())
  code            String   // e.g., "ENG-101"
  name            String
  section         String   @default("1")  // Section number
  credits         Int      @default(3)    // Credit hours
  semester        String?                 // e.g., "1/2567", "2/2567"
  academicYear    Int?                    // e.g., 2567
  room            String?                 // Room number/location
  capacity        Int?                    // Max students
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  teacher         User     @relation("TeacherClasses", fields: [teacherId], references: [id])
  teacherId       String

  students        Enrollment[]
  joinRequests    JoinRequest[] @relation("ClassJoinRequests")
  assignments     Assignment[]
  attendances     Attendance[]
  assemblyAttendances AssemblyAttendance[]
  attendanceSessions AttendanceSession[]
  exams           Exam[]
  meetings        Meeting[]
  schedules       Schedule[]
  resources       Resource[]
  announcements   Announcement[]
  gradeItems      GradeItem[]
  classOrganizations ClassOrganization[]
  materials       TeachingMaterial[] @relation("ClassMaterials")

  @@unique([code, section, semester])
  @@index([teacherId])
  @@index([code])
  @@index([semester])
}

model Enrollment {
  id              String   @id @default(cuid())
  enrolledAt      DateTime @default(now())
  status          String   @default("active") // active, dropped, completed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  student         User     @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  studentId       String
  class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId         String

  @@unique([classId, studentId])
  @@index([studentId])
  @@index([classId])
}

model GradeItem {
  id              String   @id @default(cuid())
  name            String   // e.g., "Midterm Exam", "Assignment 1"
  itemType        String   @default("assignment") // assignment, exam, quiz, participation
  maxScore        Float    @default(100)
  weight          Float    @default(0.1) // 0.1 = 10%
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId         String

  gradeRecords    GradeRecord[]

  @@index([classId])
}

model GradeRecord {
  id              String   @id @default(cuid())
  score           Float
  percentage      Float?
  grade           String?  // A, B, C, D, F
  feedback        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  student         User     @relation("StudentGrades", fields: [studentId], references: [id], onDelete: Cascade)
  studentId       String
  gradeItem       GradeItem @relation(fields: [gradeItemId], references: [id], onDelete: Cascade)
  gradeItemId     String

  @@unique([gradeItemId, studentId])
  @@index([studentId])
  @@index([gradeItemId])
}

model Advisor {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String?
  office    String?
  bio       String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  @@index([email])
}

model Community {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())

  members CommunityMember[]

  @@index([name])
}

model CommunityMember {
  id String @id @default(cuid())

  user        User      @relation(fields: [userId], references: [id])
  userId      String
  community   Community @relation(fields: [communityId], references: [id])
  communityId String
  role        String    @default("member")

  @@unique([communityId, userId])
  @@index([userId])
}

model Organization {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())

  positions ClassOrganization[]

  @@index([name])
}

model ClassOrganization {
  id String @id @default(cuid())

  position String // President, Vice President, Treasurer, etc
  user     User   @relation(fields: [userId], references: [id])
  userId   String

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  class          Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId        String

  @@unique([organizationId, classId, userId])
  @@index([classId, organizationId])
}

model RegisterService {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  category    String   // การลงทะเบียน, เอกสาร, สถานภาพ, etc
  status      String   @default("online") // online, onsite, mixed, closed
  eta         String?  // estimated time e.g., "3-5 working days"
  fee         Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requests ServiceRequest[]

  @@index([category, status])
}

model ServiceRequest {
  id        String   @id @default(cuid())
  status    String   @default("pending") // pending, approved, rejected, completed
  appliedAt DateTime @default(now())
  completedAt DateTime?
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  student   User            @relation(fields: [studentId], references: [id])
  studentId String
  service   RegisterService @relation(fields: [serviceId], references: [id])
  serviceId String

  @@unique([serviceId, studentId])
  @@index([studentId, status])
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileUrl     String
  fileType    String   // pdf, video, document, etc
  size        Int?     // in bytes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId String

  @@index([classId, fileType])
}

model Announcement {
  id              String   @id @default(cuid())
  title           String
  content         String
  category        String   @default("ประกาศ") // ประกาศ, ข่าวกิจกรรม, ชุมชน & ชมรม
  image           String?  // announcement image URL
  excerpt         String?  // short summary
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  author          User     @relation("TeacherAnnouncements", fields: [authorId], references: [id], onDelete: Cascade)
  authorId        String
  class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId         String

  @@index([classId, createdAt])
  @@index([authorId])
}

// ============ CHAT EXTENDED MODELS ============

model ChatNote {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String

  @@index([roomId, updatedAt])
  @@index([authorId])
}

model ChatFile {
  id         String   @id @default(cuid())
  fileName   String
  mimeType   String
  sizeBytes  Int
  url        String   // S3 URL or local path
  width      Int?     // for images
  height     Int?     // for images
  createdAt  DateTime @default(now())

  // Relations
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  uploader  User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  uploaderId String

  // Message reference if file was uploaded as attachment
  message   Message? @relation("MessageFiles", fields: [messageId], references: [id])
  messageId String?
  legacyMessage Message? @relation("MessageFile")

  @@index([roomId, createdAt])
  @@index([uploaderId])
}

model RoomPin {
  id        String   @id @default(cuid())
  pinnedAt  DateTime @default(now())

  // Relations
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  @@unique([roomId, userId], name: "roomId_userId")
  @@index([userId, pinnedAt])
  @@index([roomId])
}

model MessageRead {
  id        String   @id @default(cuid())
  readAt    DateTime @default(now())

  // Relations
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  @@unique([messageId, userId])
  @@index([userId, readAt])
}

// ============ NEW FEATURES: JOIN REQUESTS, TEACHING MATERIALS ============

model JoinRequest {
  id              String   @id @default(cuid())
  status          String   @default("pending") // pending, approved, rejected
  reason          String?  // reason for rejection
  respondedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  student         User     @relation("StudentJoinRequests", fields: [studentId], references: [id], onDelete: Cascade)
  studentId       String
  class           Class    @relation("ClassJoinRequests", fields: [classId], references: [id], onDelete: Cascade)
  classId         String

  @@unique([classId, studentId])
  @@index([studentId])
  @@index([classId, status])
}

model TeachingMaterial {
  id              String   @id @default(cuid())
  title           String
  description     String?
  type            String   // FILE or LINK
  fileUrl         String?  // URL for file storage
  linkUrl         String?  // External link
  fileType        String?  // pdf, docx, pptx, etc
  createdBy       String   // teacher ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  class           Class    @relation("ClassMaterials", fields: [classId], references: [id], onDelete: Cascade)
  classId         String

  @@index([classId, createdAt])
}
