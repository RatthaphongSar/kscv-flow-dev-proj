// backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")   // ← ดึงจาก .env
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String  
  role         String   @default("STUDENT")
  year         Int
  major        String
  rooms        RoomMember[]
  messages     Message[]
}


model Room {
  id        String       @id @default(cuid())
  name      String       @unique
  type      String
  members   RoomMember[]
  messages  Message[]

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}


model RoomMember {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String
  room   Room   @relation(fields: [roomId], references: [id])
  roomId String

  @@unique([roomId, userId], name: "roomId_userId")
  @@index([userId])
  @@index([roomId])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  room      Room     @relation(fields: [roomId], references: [id])
  roomId    String

  @@index([roomId, createdAt])
}
