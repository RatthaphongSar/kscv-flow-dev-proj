# ============================================================
# KVC Self-Hosted Production Configuration
# ============================================================
# Use this file when running docker-compose.self-hosted.yml
#
# Run with:
#   docker compose -f docker-compose.self-hosted.yml --env-file .env.production up -d
#
# ⚠️  IMPORTANT: Change ALL secrets to strong random values!
#

# ============================================================
# DATABASE
# ============================================================
POSTGRES_PASSWORD=your-strong-secure-password-here

# ============================================================
# REDIS
# ============================================================
REDIS_PASSWORD=your-strong-redis-password-here

# ============================================================
# JWT & AUTHENTICATION
# ============================================================
JWT_ACCESS_SECRET=a3f8e2d1c9b4a7f2e8d1c3b5a7f9e2d4c6b8a1f3e5d7c9b1a3f5e7d9c1b3a5
JWT_REFRESH_SECRET=b4f9e3d2c0b5a8f3e9d2c4b6a8f0e3d5c7b9a2f4e6d8c0b2a4f6e8d0c2b4a6

# ============================================================
# FRONTEND & BACKEND URLs
# ============================================================
# Frontend URL (for CORS in backend)
# When accessed via http://<your-machine-ip>, set this:
FRONTEND_URL=https://kscv-flow-dev-proj-wi31.vercel.app/

# Backend API URL (for frontend to call backend)
# Inside Docker: backend:4001
# From frontend container: http://backend:4001
BACKEND_API_URL=https://kscv-flow-dev-proj.onrender.com

# ============================================================
# OPENAI (optional, if you use AI features)
# ============================================================
# OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================================
# NODE ENVIRONMENT
# ============================================================
NODE_ENV=production

# ============================================================
# OPTIONAL: HTTPS/SSL CERTIFICATES
# ============================================================
# If you have SSL certificates, set these:
# HTTPS=1
# HTTPS_PORT=443
# HTTPS_CERT=./certs/server.crt
# HTTPS_KEY=./certs/server.key
